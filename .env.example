# App
# PORT defaults to 3000 if unset. Put overrides in .env.local (gitignored).
# Note: Next.js does not read PORT from .env alone — `pnpm dev` loads it via dotenv-cli.
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Project Settings → API Keys)
# New projects use publishable + secret keys (legacy: anon + service_role).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Stripe (Dashboard → Developers → API keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Stripe webhooks (from `stripe listen` locally, or Dashboard → Webhooks in prod)
STRIPE_WEBHOOK_SECRET=
